   "source": [
    "x = [1, -2, -5]\n",
    "y = [4, 3, -1]\n",
    "\n",
    "def dot(x, y):\n",
    "    s = 0\n",
    "    for xi,yi in zip(x,y):\n",
    "        s += xi * yi\n",
    "    \n",
    "    return s"
   ]
